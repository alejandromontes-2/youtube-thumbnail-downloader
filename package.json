{
  "name": "youtube-thumbnail-downloader",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Download any YouTube video thumbnail in every available resolution. No login, no tracking, no backend.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
